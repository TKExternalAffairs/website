---
interface Props {
  imageSrc?: string;
  imageAlt?: string;
  middleText?: string;
  detailHref?: string;
}

const TOP_TEXT = "特別班紹介";
const BOTTOM_TEXT = "詳細はこちら";

const {
  imageSrc = "",
  imageAlt = "",
  middleText = "",
  detailHref = "#",
} = Astro.props;
---

<div
  class="w-full"
  style="padding: clamp(1rem, 2vw, 2rem) clamp(2rem, 8vw, 5rem);"
>
  <div
    class="flex aspect-[5/2] w-full overflow-hidden text-black"
    style="background-color: white;"
  >
    <div class="h-full w-3/5 bg-neutral-100">
      {
        imageSrc ? (
          <img
            src={imageSrc}
            alt={imageAlt}
            class="h-full w-full object-cover"
          />
        ) : (
          <div aria-hidden="true" class="h-full w-full bg-neutral-200" />
        )
      }
    </div>

    <div
      class="flex w-2/5 flex-col justify-center gap-6 px-6 py-8"
      style="margin: 3cm;"
    >
      <p
        class="min-h-[1.5em] text-base leading-relaxed"
        style="color: black; font-family: var(--font-hakushu); font-size: 0.8cm;"
      >
        {TOP_TEXT}
      </p>
      <p
        class="min-h-[1.5em] text-base leading-relaxed"
        style="color: black; font-family: var(--font-hakushu); font-size: 1.4cm; margin-bottom: 0.7cm;"
      >
        {middleText || "\u00A0"}
      </p>
      <a
        href={detailHref}
        class="inline-flex w-fit items-center justify-center text-base leading-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black"
        style="color: white; font-family: var(--font-hakushu); font-size: 0.6cm; text-decoration: none;"
      >
        <span
          style="background-color: black; padding: 0.4em 0.4em; box-decoration-break: clone; -webkit-box-decoration-break: clone;"
        >
          {BOTTOM_TEXT}
        </span>
      </a>
    </div>
  </div>
</div>
