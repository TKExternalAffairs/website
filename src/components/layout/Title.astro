---
const { title, heroImage } = Astro.props;
---

<section
  class="relative flex h-[32rem] items-center justify-center overflow-hidden rounded-lg bg-gray-950"
>
  {
    heroImage && (
      <img
        src={heroImage}
        alt=""
        aria-hidden="true"
        role="presentation"
        class="absolute inset-0 h-full w-full object-cover opacity-40"
      />
    )
  }
  <h1
    class="font-hakushu relative z-10 text-center text-3xl tracking-[0.2em] [writing-mode:vertical-lr] sm:text-4xl"
  >
    {title}
  </h1>
</section>
