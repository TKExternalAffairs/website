---
import { Image } from "astro:assets";
import logoImage from "../../assets/SVG/logo.svg";
import shogaiLogoImage from "../../assets/SVG/shogai_logo.svg";
---

{/* FIXME: border-doubleが効いてなさそう */}
<span class="relative block w-full border-t border-white py-px"></span>
<footer
  class="mt-auto w-full justify-items-center border-t border-double border-white px-4 pt-16"
>
  <div class="flex flex-col gap-16 md:gap-24">
    <!-- ロゴと住所 -->
    <div
      class="flex max-w-5xl flex-col justify-center gap-x-[10%] px-12 md:flex-row"
    >
      <Image src={logoImage} alt="ロゴ" class="w-64" />
      <address class="text-center whitespace-nowrap not-italic md:text-left">
        <p class="text-md mb-2">第七十五回筑駒文化祭 高三特別班</p>
        <p class="mb-3 text-[0.6rem] leading-loose tracking-wide">
          The 75th Tsukukoma School Festival The 12th Grade Special Teams
        </p>
        <p class="text-[0.6rem] leading-loose tracking-wide">
          &#12306;154-0001 東京都世田谷区池尻4-7-1 筑波大学附属駒場高等学校
        </p>
      </address>
    </div>
    <!-- 設計・制作 -->
    <div class="flex flex-col items-center">
      <p class="font-light">Designed and Produced by</p>

      <Image
        src={shogaiLogoImage}
        alt="高三特別班 渉外事務局 ロゴ"
        class="w-64 object-contain md:w-80"
        fetchpriority="low"
      />
    </div>
    <p class="px-2 pb-10 text-center text-xs tracking-wide">
      &copy;THE 75TH TSUKUKOMA SCHOOL FESTIVAL THE 12TH GRADE SPEACIAL TEAMS,
      All rights reserved
    </p>
  </div>
</footer>
