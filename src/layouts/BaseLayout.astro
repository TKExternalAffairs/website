---
import { SITE_NAME, canonicalUrl, siteIndexingEnabled } from "../lib/site";
import "../styles/global.css";
import defaultOgpImageRaw from "../assets/hero_desktop.webp";
import { getImage } from "astro:assets";
import type { ArticleProp } from "../lib/ogp-types";
import ArticleMeta from "../components/ArticleMeta.astro";

interface Props {
  title?: string;
  description?: string;
  ogpImageUrl?: string;
  ogpType?: string;
  /**
   * og:typeがarticleのときのみ有効
   */
  articleProperties?: [ArticleProp];
  canonicalPath?: string;
  noIndex?: boolean;
}

const defaultOgpImage = await getImage({
  src: defaultOgpImageRaw,
  format: "webp",
});

const {
  title,
  description,
  ogpImageUrl = defaultOgpImage.src,
  ogpType = "website",
  articleProperties,
  canonicalPath = Astro.url.pathname,
  noIndex = !siteIndexingEnabled,
} = Astro.props as Props;

const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const pageDescription = description ?? title ?? SITE_NAME;
const canonical = canonicalUrl(canonicalPath);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="robots"
      content={noIndex ? "noindex, nofollow" : "index, follow"}
    />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="dns-prefetch" href="https://use.typekit.net" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:image" content={ogpImageUrl} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogpType} />
    {
      articleProperties?.map((prop) => {
        <ArticleMeta articleProp={prop} />;
      })
    }
    <meta property="twitter:url" content={canonical} />
    <script>
      // Adobe FontsからAH白洲をフェッチする
      declare const Typekit: {
        load(config: unknown): void;
      };
      (function (d) {
        var config = {
            kitId: "hxo7nit",
            scriptTimeout: 3000,
            async: true,
          },
          h = d.documentElement,
          t = setTimeout(function () {
            h.className =
              h.className.replace(/\bwf-loading\b/g, "") + " wf-inactive";
          }, config.scriptTimeout),
          tk = d.createElement("script"),
          s = d.getElementsByTagName("script")[0];
        h.className += " wf-loading";
        tk.src = "https://use.typekit.net/" + config.kitId + ".js";
        tk.async = true;
        tk.onload = function () {
          clearTimeout(t);
          try {
            Typekit.load(config);
          } catch (e) {}
        };
        s.parentNode?.insertBefore(tk, s);
      })(document);
    </script>
  </head>
  <body>
    <slot />
  </body>
  <!-- Cloudflare Web Analytics -->
  <script
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon='{"token": "61cfec07a7804d62b0ba9e1ca20da31a"}'></script>
  <!-- End Cloudflare Web Analytics -->
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    color: white;
    background-color: var(--background-primary);
    /* TODO: 游ゴシック ミディアム 体ってこれであってる？ */
    font-family: "Yu Gohic", "游ゴシック", sans-serif;
  }
</style>

<script is:inline>
  const theme = (() => {
    const localStorageTheme = localStorage?.getItem("theme") ?? "";
    if (["dark", "light"].includes(localStorageTheme)) {
      return localStorageTheme;
    }
    if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
      return "dark";
    }
    return "light";
  })();

  document.documentElement.setAttribute("data-theme", "dark"); // TODO: トグルボタン創る

  window.localStorage.setItem("theme", theme);
</script>
