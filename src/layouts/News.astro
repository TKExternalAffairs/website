---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";
import NewsTag from "../components/news/NewsTag.astro";
import type { ArticleProp } from "../lib/ogp-types";

type Props = {
  item: CollectionEntry<"news">;
};
const { item } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = item.data;

const articleProps: ArticleProp[] = [
  { type: "published_time", content: pubDate },
];
if (updatedDate) {
  articleProps.push({ type: "modified_time", content: updatedDate });
}
---

<Layout
  title={title}
  description={description}
  ogpType="article"
  articleProperties={articleProps}
>
  <section class="mx-auto pt-20 pb-5 lg:pb-20">
    <div
      class="flex flex-col items-center justify-center gap-4 p-4 text-center sm:whitespace-nowrap"
    >
      <h1 class="font-hakushu text-4xl font-bold">{title}</h1>
      <p class="text-gray-400">{description}</p>
      <p class="text-sm text-gray-500">
        公開日: {
          pubDate.toLocaleDateString("ja-JP", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })
        } / 更新日:
        {
          (updatedDate ?? pubDate).toLocaleDateString("ja-JP", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })
        }
      </p>
      {
        tags.length > 0 && (
          <ul class="mt-1 flex flex-wrap justify-center gap-2">
            {tags.map((tagId) => (
              <li class="list-none">
                <NewsTag tagId={tagId} />
              </li>
            ))}
          </ul>
        )
      }
      {
        heroImage && (
          <div class="mt-8 flex justify-center">
            <Image
              src={heroImage}
              alt={title}
              class="w-full max-w-2xl object-cover"
            />
          </div>
        )
      }
    </div>

    <slot />
  </section>
</Layout>
