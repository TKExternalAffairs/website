---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import NoImageSVG from "../../assets/SVG/noimage.svg";
import Layout from "../../layouts/Layout.astro";
import Title from "../../components/layout/Title.astro";
import NewsTag from "../../components/news/NewsTag.astro";
import SunsetImage from "../../assets/sunset.jpeg";
import { isVisibleInCurrentSite } from "../../lib/site";

const newsItems = (await getCollection("news"))
  .filter((item) => isVisibleInCurrentSite(item.data.publishTargets))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="お知らせ" description="高三特別班のお知らせ一覧です。">
  <Title title="お知らせ" heroImage={SunsetImage.src} />
  <section class="mx-auto w-full max-w-6xl px-4 py-12">
    {
      newsItems.length === 0 ? (
        <p class="text-gray-300">現在、お知らせはありません。</p>
      ) : (
        <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {newsItems.map((item) => (
            <li class="group list-none border border-gray-600 transition duration-500 hover:border-gray-400">
              <a href={`/news/${item.id}/`} class="block p-4">
                <div class="mb-4 aspect-4/3 w-full overflow-hidden bg-gray-900">
                  {item.data.heroImage ? (
                    <Image
                      src={item.data.heroImage}
                      alt={item.data.title}
                      class="h-full w-full object-cover transition-transform duration-600 group-hover:scale-120"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center text-sm text-gray-400 transition-transform duration-600 group-hover:scale-120">
                      <NoImageSVG class="fill-white" />
                    </div>
                  )}
                </div>
                <h2 class="font-hakushu text-2xl font-bold">
                  {item.data.title}
                </h2>
                {item.data.tags.length > 0 && (
                  <ul class="mt-3 mb-2 flex flex-wrap gap-2">
                    {item.data.tags.map((tagId) => (
                      <li class="list-none">
                        <NewsTag tagId={tagId} />
                      </li>
                    ))}
                  </ul>
                )}
                <p class="text-sm text-gray-500">
                  {item.data.pubDate.toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>
