---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const newsItems = (await getCollection("news")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout>
  <section class="mx-auto w-full max-w-4xl px-4 py-12">
    <h1 class="mb-8 text-3xl font-bold">お知らせ</h1>
    {
      newsItems.length === 0 ? (
        <p class="text-gray-300">現在、お知らせはありません。</p>
      ) : (
        <ul class="space-y-4">
          {newsItems.map((item) => (
            <li class="rounded-lg border border-gray-700 p-4 transition hover:border-gray-400">
              <a href={`/news/${item.id}/`} class="block">
                <p class="text-sm text-gray-400">
                  {item.data.pubDate.toLocaleDateString("ja-JP")}
                </p>
                <h2 class="mt-1 text-xl font-semibold">{item.data.title}</h2>
                <p class="mt-2 text-gray-300">{item.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>
