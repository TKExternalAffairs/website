---
import Layout from "../../layouts/Layout.astro";
import Title from "../../components/layout/Title.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import shutokoLogo from "../../assets/sponsors/shutoko.jpg";
import blueqatLogo from "../../assets/sponsors/blueqat.png";
import kinujoLogo from "../../assets/sponsors/Kinujo.png";

type SponsorLogo = {
  image: ImageMetadata;
  alt: string;
  href: string;
};

const sponsorLarge: SponsorLogo[] = [
  {
    image: shutokoLogo,
    alt: "首都高速道路株式会社",
    href: "https://www.shutoko.co.jp/",
  },
];

const sponsorSmall: SponsorLogo[] = [
  {
    image: blueqatLogo,
    alt: "blueqat株式会社",
    href: "https://blueqat.co.jp/",
  },
  {
    image: kinujoLogo,
    alt: "KINUJO",
    href: "https://kinujo.jp/",
  },
];

const sponsorTextOnly: string[] = [];
---

<Layout title="協賛のお願い" description="高三特別班の協賛に関するご案内です。">
  <Title title="ご協賛のお願い" heroImage="/images/kyousan-hero.png" />

  <section
    class="mx-auto w-full max-w-5xl px-4 py-12 text-sm leading-8 text-gray-100 sm:px-6 sm:text-base lg:px-8"
  >
    <div class="space-y-8">
      <p>
        平素は筑駒文化祭の運営につきまして、格別のご理解とご協力を賜り、厚く御礼申し上げます。
      </p>

      <p>
        筑駒文化祭は今年度で75回目を迎え、企画・運営から当日の実施に至るまで、
        すべて生徒の手によって創り上げられる「生徒主体」の伝統を大切に、準備を進めています。
        とりわけ、本校文化祭の最大の見どころとなっているのが、高校3年生による特別班「高三特別班」で、
        ステージや縁日の運営、食品の提供など他学年にはない大規模な企画を実施しており、
        約15,000名の来場者の皆様に唯一無二の体験を提供しています。
      </p>

      <p>
        一方で、近年の物価高の影響を受け、食品提供などに使用されるチケットの販売価格が
        昨年度約1.3倍に引き上げられた他、必要な器材の不足から準備の遅滞が見られる例も少なくありません。
      </p>

      <p>
        私たちは、物販が過度な営利に走ることを防ぎ、文化祭としての純粋な価値を守り抜きたいと考えています。
        その一環として、今年度の筑駒文化祭では企業協賛を募集いたします。
        つきましては、誠に恐縮ではございますが、本文化祭の趣旨にご賛同いただき、
        何卒ご協賛を賜りたくお願い申し上げる次第です。
        賜りましたご支援は、文化祭の食品提供や準備費、器材購入に大切に活用させていただきます。
      </p>

      <p>
        ご支援いただきました折には、ホームページや当日配布する公式パンフレット、
        文化祭当日に開設する特設掲示板などに貴社名やロゴを掲示・掲載させていただきます。
      </p>

      <p>
        ご興味を持っていただけましたら、以下のフォームよりお問い合わせください。
        より詳細な資料（協賛募集要項）を用意しております。
      </p>

      <p>
        高校生活最後の文化祭を最高傑作に創り上げるため、全力を尽くしてまいります。
        何卒、温かいご支援を賜りますようお願い申し上げます。
      </p>

      <div class="pt-4 text-right leading-8">
        <p class="font-hakushu text-base font-bold sm:text-lg">
          筑波大学附属駒場中・高等学校
        </p>
        <p
          class="font-hakushu text-base font-bold whitespace-nowrap sm:text-lg"
        >
          高三特別班　渉外事務局
        </p>
        <p
          class="font-hakushu text-base font-bold whitespace-nowrap sm:text-lg"
        >
          顧問　早川 和彦
        </p>
        <p
          class="font-hakushu text-base font-bold whitespace-nowrap sm:text-lg"
        >
          事務局長　中河 颯太
        </p>
      </div>

      <div class="flex justify-center pt-8">
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLScsHTXduQxnxs4hnpr29Zb6e_swytknrjQmu8agCn63ujmZcw/viewform"
          target="_blank"
          class="inline-flex w-full max-w-[320px] items-center justify-center bg-white px-4 py-3 text-center text-base whitespace-nowrap text-black transition hover:opacity-80 sm:w-auto sm:max-w-none sm:px-8 sm:py-4 sm:text-2xl md:px-10 md:text-[28px]"
          style="font-family: 'Yu Mincho', 'Hiragino Mincho ProN', 'MS PMincho', serif; font-weight: 700; letter-spacing: 0.08em;"
        >
          お問い合わせフォーム
        </a>
      </div>
    </div>
  </section>

  <section id="sponsors" class="bg-[#e9e9e9] py-20 text-black">
    <div class="mx-auto w-full max-w-[1700px] px-6">
      <div class="text-center">
        <h2
          class="text-5xl"
          style="font-family: 'Yu Mincho', 'Hiragino Mincho ProN', 'MS PMincho', serif; font-weight: 700; letter-spacing: 0.12em;"
        >
          協賛企業一覧
        </h2>
        <p class="mx-auto mt-8 max-w-4xl text-[20px] leading-9">
          以下の企業の皆様より、第75回筑駒文化祭へのご支援を賜りました。ここに深く御礼申し上げます。
        </p>
      </div>

      <div class="mt-16 space-y-10">
        {
          sponsorLarge.length > 0 && (
            <div class="flex flex-wrap justify-center gap-x-8 gap-y-8">
              {sponsorLarge.map((sponsor) => (
                <a
                  href={sponsor.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-[200px] w-[300px] items-center justify-center border-[4px] border-black bg-white p-3 transition hover:opacity-80"
                >
                  <Image
                    src={sponsor.image}
                    alt={sponsor.alt}
                    class="block max-h-full max-w-full object-contain object-center"
                  />
                </a>
              ))}
            </div>
          )
        }

        {
          sponsorSmall.length > 0 && (
            <div class="flex flex-wrap justify-center gap-x-8 gap-y-8">
              {sponsorSmall.map((sponsor) => (
                <a
                  href={sponsor.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-[100px] w-[300px] items-center justify-center border-[4px] border-black bg-white p-3 transition hover:opacity-80"
                >
                  <Image
                    src={sponsor.image}
                    alt={sponsor.alt}
                    class="block max-h-full max-w-full object-contain object-center"
                  />
                </a>
              ))}
            </div>
          )
        }

        {
          sponsorTextOnly.length > 0 && (
            <div class="px-12 pt-12">
              <div class="flex flex-wrap items-center gap-x-16 gap-y-6">
                {sponsorTextOnly.map((name) => (
                  <p style="font-family: 'Yu Gothic Medium', 'Yu Gothic', YuGothic, sans-serif; font-size: 30px; line-height: 1;">
                    ・{name}
                  </p>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </section>
</Layout>
