---
import Layout from "../../layouts/Layout.astro";
import GroupIntroBox from "../../components/GroupIntroBox.astro";
import stageImage from "./assets/stageImage.png";
import introDuctImage from "./assets/タイトル画像.png";
import shougaiImage from "./assets/特別班渉外事務局.png";
const overlayText = "各班紹介";
---

<Layout>
    <section class="stage-hero" aria-label="ステージ企画タイトル">
        <img src={introDuctImage.src} alt="タイトル画像" class="stage-hero__image" />
        <div class="stage-hero__textbox" aria-hidden="true">
            <span>{overlayText}</span>
        </div>
    </section>
    <GroupIntroBox 
        imageSrc={stageImage.src}
        imageAlt="ステージ班のイメージ画像"
        middleText="高三ステージ班"
        detailHref="/groups/stage"
    >
    </GroupIntroBox>
    
    <GroupIntroBox 
        imageSrc= ""
        imageAlt="縁日班のイメージ画像"
        middleText="高三縁日班"
        detailHref="/groups/ennichi"
    >
    </GroupIntroBox>
    
    <GroupIntroBox 
        imageSrc= ""
        imageAlt="食品班のイメージ画像"
        middleText="高三食品班"
        detailHref="/groups/shokuhin"
    >
    </GroupIntroBox>
    
    <GroupIntroBox 
        imageSrc= ""
        imageAlt="喫茶班のイメージ画像"
        middleText="高三喫茶班"
        detailHref="/groups/kissa"
    >
    </GroupIntroBox>
    
    <GroupIntroBox 
        imageSrc= ""
        imageAlt="コント班のイメージ画像"
        middleText="高三コント班"
        detailHref="/groups/konto"
    >
    </GroupIntroBox>

    <GroupIntroBox 
        imageSrc= ""
        imageAlt="対話班のイメージ画像"
        middleText="高三対話班"
        detailHref="/groups/taiwa"
    >
    </GroupIntroBox>

    <GroupIntroBox 
        imageSrc= {shougaiImage.src}
        imageAlt="渉外事務局のイメージ画像"
        imageWidth="100%"
        imageHeight="auto"
        imagePadding="4cm"
        middleText="渉外事務局"
        detailHref="/groups/shougai"
    >
    </GroupIntroBox>
        
    <GroupIntroBox 
        imageSrc= ""
        imageAlt="お土産部門のイメージ画像"
        middleText="お土産部門"
        detailHref="/groups/omiyage"
    >
    </GroupIntroBox>
</Layout>

<style>
    .stage-hero {
        position: relative;
        width: 100%;
        margin: 0;
        padding: 0;
    }

    .stage-hero__image {
        display: block;
        width: 100%;
        height: auto;
    }

    .stage-hero__textbox {
        position: absolute;
        top: 50%;
        left: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: clamp(12rem, 42vw, 24rem);
        padding: clamp(1rem, 2vw, 1.5rem) clamp(0.75rem, 1.8vw, 1rem);
        background: rgba(6, 6, 6, 0.5);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(8px);
        transform: translate(-50%, -50%);
    }

    .stage-hero__textbox span {
        writing-mode: vertical-rl;
        text-orientation: upright;
        font-family: var(--font-hakushu);
        font-size: clamp(1.5rem, 4vw, 3.25rem);
        line-height: 1;
        letter-spacing: 0.35rem;
        color: white;
        text-shadow: 0 4px 18px rgba(0, 0, 0, 0.35);
    }

    @media (max-width: 640px) {
        .stage-hero__textbox {
            min-height: clamp(9rem, 46vw, 14rem);
            padding: 0.85rem 0.65rem;
        }

        .stage-hero__textbox span {
            letter-spacing: 0.22rem;
        }
    }
</style>